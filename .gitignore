# .gitignore for Nexora

# Dependencies
node_modules/
packages/
.nuget/packages/

# Build outputs
bin/
obj/
dist/
build/
*.dll
*.exe
*.so
*.dylib

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Test coverage
coverage/
*.lcov
.nyc_output/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Secrets & sensitive data
.env
.env.local
.env.*.local
.secrets/
**/secrets.json
appsettings.Development.json

# OS
Thumbs.db
.DS_Store
*.tmp

# Docker
docker-compose.override.yml
.dockerignore

# Database
*.db
*.sqlite
*.sqlite3
data/

# Temporary files
tmp/
temp/
*.bak
*.backup

# User-specific files
.idea/workspace.xml
.idea/tasks.xml
.vscode/settings.json

# Package manager
package-lock.json
yarn.lock
pnpm-lock.yaml
