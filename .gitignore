# =========================
# Nexora .gitignore
# =========================

# -------------------------
# Build outputs
# -------------------------
bin/
obj/
dist/
build/
out/
publish/

# -------------------------
# .NET / NuGet
# -------------------------
.nuget/
packages/

# Rider / VS / VSCode
.vs/
.vscode/
.idea/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider
.idea/workspace.xml
.idea/tasks.xml

# VSCode optional local settings
.vscode/settings.json

# -------------------------
# Node / Frontend
# -------------------------
node_modules/
.npm/
.pnpm-store/

# Keep lock files committed
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -------------------------
# Logs
# -------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------
# Test / Coverage
# -------------------------
coverage/
TestResults/
test-results/
*.trx
*.coverage
*.coveragexml
*.lcov
.nyc_output/

# -------------------------
# Environment / Secrets
# -------------------------
.env
.env.*
!.env.example

.secrets/
**/secrets.json

# Keep template configs
# Ignore only local overrides
appsettings.Development.json
appsettings.Local.json

# AWS / Azure credentials
.aws/
.azure/

# -------------------------
# Docker
# -------------------------
docker-compose.override.yml

# Do NOT ignore .dockerignore
# It should be committed

# -------------------------
# Database / Local storage
# -------------------------
*.db
*.sqlite
*.sqlite3

data/
storage/

# -------------------------
# Terraform
# -------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Keep lock file committed
# .terraform.lock.hcl

# -------------------------
# Temporary files
# -------------------------
tmp/
temp/
*.tmp
*.bak
*.backup
*~
*.tsbuildinfo

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -------------------------
# Misc
# -------------------------
*.swp
*.swo

# -------------------------
# Generated artifacts
# -------------------------
artifacts/
# UI generated artifacts
src/Nexora.UI/playwright-report/
src/Nexora.UI/test-results/
src/Nexora.UI/dist/
